# Populated by `git archive` at archive time via export-subst. In a normal
# checkout these stay as literal placeholder strings, and the build ignores
# them. The file is here so that source archives generated by `git archive`
# carry enough version metadata for the build to reproduce versionCode and
# versionName without a .git directory.
describe=$Format:%(describe:tags=true)$
commit=$Format:%H$
commit-date=$Format:%cI$
ref-names=$Format:%D$
